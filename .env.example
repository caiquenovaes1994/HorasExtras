# Exemplo de configuração de ambiente (.env)
# Renomeie este arquivo para .env e preencha os valores.

# Chave de Criptografia (Fernet) - Use o comando sugerido para gerar uma nova.
SECRET_KEY=SUA_CHAVE_GERADA_AQUI

# Senha Inicial do Administrador (cnovaes)
ADMIN_PWD=mudar123

# ── Conexão PostgreSQL (Supabase) ──────────────────────────────────────────
# Encontre esses valores em: Supabase Dashboard → Project Settings → Database
DB_HOST=db.xxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASS=SUA_SENHA_DO_SUPABASE
